---
interface Props {
  class?: string
  /** Locale-aware privacy link; defaults to the EN policy. */
  privacyHref?: string
  privacyLabel?: string
  /** Path of this page in the other language, for the language switch link. */
  altLangHref?: string
  altLangLabel?: string
}
const {
  class: className = '',
  privacyHref = '/privacy',
  privacyLabel = 'Privacy',
  altLangHref,
  altLangLabel
} = Astro.props
---

<footer
  class:list={[
    'mx-auto flex max-w-6xl flex-col items-start justify-start gap-2 md:flex-row md:items-center md:justify-between',
    className
  ]}
>
  <span class="text-muted-foreground/80 text-sm leading-snug uppercase">
    (c) 2026 ArticleLens
  </span>

  <div class="flex items-center gap-4">
    <a
      href={privacyHref}
      class="text-muted-foreground/80 hover:text-muted-foreground text-sm leading-snug uppercase transition-colors"
    >
      {privacyLabel}
    </a>
    {
      altLangHref && (
        <a
          href={altLangHref}
          class="text-muted-foreground/80 hover:text-muted-foreground text-sm leading-snug uppercase transition-colors"
        >
          {altLangLabel}
        </a>
      )
    }
    <a
      href="https://github.com/vab1997/article-lens"
      target="_blank"
      rel="noopener noreferrer"
      class="text-muted-foreground/80 hover:text-muted-foreground text-sm leading-snug uppercase transition-colors"
    >
      GitHub
    </a>
    <a
      href="https://x.com/victorbejas"
      target="_blank"
      rel="noopener noreferrer"
      class="text-muted-foreground/80 hover:text-muted-foreground text-sm leading-snug uppercase transition-colors"
    >
      @victorbejas
    </a>
  </div>
</footer>
